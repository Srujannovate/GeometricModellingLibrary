<Window x:Class="GML_WPF.Pmi.PmiListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PMI Annotations" Height="400" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <DataGrid x:Name="Grid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"      Binding="{Binding Id}"          Width="80" />
                <DataGridTextColumn Header="Kind"    Binding="{Binding Kind}"        Width="140" />
                <DataGridTextColumn Header="Display" Binding="{Binding DisplayText}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
